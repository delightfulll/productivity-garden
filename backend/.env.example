PORT=3000

# ── Local development (TCP) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database

# ── Cloud Run → Cloud SQL (Unix socket) ───────────────────────
# Set this in production instead of DB_HOST/DB_PORT.
# Format: /cloudsql/PROJECT_ID:REGION:INSTANCE_ID
# INSTANCE_UNIX_SOCKET=/cloudsql/my-project:us-central1:my-instance

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave blank to allow all origins (not recommended in production).
# CORS_ORIGIN=https://your-app.vercel.app
